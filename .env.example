APP_NAME=llm-orchestrator
APP_ENV=dev
LOG_LEVEL=INFO
PORT=8000
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
GATEWAY_API_KEY=
GATEWAY_API_KEYS=
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

GROQ_ENABLED=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=3.0
GROQ_PRIORITY=1

OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=5.0
OPENROUTER_PRIORITY=2
OPENROUTER_REFERER=
OPENROUTER_TITLE=llm-orchestrator

HUGGINGFACE_ENABLED=false
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_TIMEOUT_SECONDS=8.0
HUGGINGFACE_PRIORITY=3

REFINEMENT_STRATEGY=aggregate
MAX_PARALLEL_PROVIDERS=3
PROVIDER_MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=0.25
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

N8N_BASE_URL=https://your-n8n-host.up.railway.app
N8N_API_KEY=
N8N_TIMEOUT_SECONDS=10.0
N8N_COMPLEXITY_THRESHOLD=80

INFISICAL_ENABLED=false
INFISICAL_HOST=https://app.infisical.com
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT_SLUG=dev
INFISICAL_SECRET_PATH=/
